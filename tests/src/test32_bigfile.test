#! /bin/sh

RSYNC_CLIENT_EXECUTOR=sudo
RSYNC_SERVER_EXECUTOR=sudo
# Test >4G files for 64-to-32 bit shortening issues.

set -e
set -u

. ${tstdir-.}/lib.sh
. ${tstdir-.}/conf.sh

rm -f bigfile bigfile.out

dd if=/dev/random of=bigfile bs=1M count=$((1024 * 4 + 128))
if [ -z "$RSYNC_DEBUG" ]; then
	trap 'rm -f bigfile bigfile.out' EXIT
fi

rsync -- bigfile bigfile.out

# 32-bit platforms have historically written a truncated bigfile.out due to
# size_t overflow, so we compare them after to be safe.
if ! cmp -s bigfile bigfile.out; then
	1>&2 echo "Transfer succeeded, but output differs"
	1>&2 ls -l bigfile bigfile.out
	exit 1
fi
